# Copy to .env.local and fill in real values. Never commit .env.local.

# Public site URL — used for canonical URLs, sitemap, and JSON-LD. Set to the
# real production domain once deployed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# EmailJS — powers the contact form directly from the browser. All three are
# browser-safe public identifiers (EmailJS is designed for client-side use;
# abuse is guarded by domain allow-listing in the EmailJS dashboard). Get them
# at https://dashboard.emailjs.com.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Server-only, optional — raises the GitHub REST API rate limit used by
# /api/github. The route works unauthenticated at hourly revalidation
# without this; add a personal access token (no scopes needed for public
# data) only if stats stop refreshing due to rate limiting.
GITHUB_TOKEN=
